# ============================================================
# Shift Solver AI — Variables de entorno
# Copia como .env.local para desarrollo / configura en Vercel
# ============================================================

# ── Base de datos (PostgreSQL) ─────────────────────────────
# Vercel: usa Vercel Postgres o Neon/Supabase
DATABASE_URL="postgresql://user:password@host:5432/shift_solver_db?sslmode=require"

# ── Auth.js (NextAuth v5) ──────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET="genera-con-openssl-rand-base64-32"
# En Vercel: https://tu-app.vercel.app
AUTH_URL="https://tu-app.vercel.app"

# ── Solver OR-Tools (Railway) ──────────────────────────────
SOLVER_API_URL="https://shift-solver-ai-production.up.railway.app"
SOLVER_API_KEY="tu-api-key-del-solver"

# ── App (públicas — safe para el cliente) ─────────────────
NEXT_PUBLIC_APP_URL="https://tu-app.vercel.app"
NEXT_PUBLIC_APP_NAME="Shift Solver AI"
